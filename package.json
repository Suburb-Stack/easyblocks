{
  "name": "@suburb-stack/monorepo",
  "private": true,
  "scripts": {
    "dev": "lerna run --stream dev --scope '@suburb-stack/core' --scope '@suburb-stack/editor'",
    "nuke": "./scripts/nuke.sh",
    "clean": "./scripts/clean.sh",
    "build": "nx run-many --target build --exclude website",
    "test": "nx run-many --target test",
    "lint": "nx affected --target lint --base origin/main -- --quiet",
    "lint:packages": "nx run-many --target lint --projects '@suburb-stack/*' -- --quiet",
    "lint:all": "nx run-many --target lint -- --quiet",
    "check": "nx run-many --target check",
    "prepare": "husky",
    "publish-prerelease": "lerna version prerelease && npm run build && lerna publish from-git",
    "supabase-start": "supabase start",
    "supabase-stop": "supabase stop",
    "supabase-restart": "npm run supabase-stop && npm run supabase-start"
  },
  "devDependencies": {
    "@babel/core": "^7.28.6",
    "@babel/plugin-transform-runtime": "^7.28.5",
    "@babel/preset-env": "^7.28.6",
    "@babel/preset-react": "^7.28.5",
    "@babel/preset-typescript": "^7.28.5",
    "@jest/types": "^30.2.0",
    "@microsoft/api-extractor": "^7.55.2",
    "@rollup/plugin-babel": "^6.1.0",
    "@rollup/plugin-commonjs": "^29.0.0",
    "@rollup/plugin-json": "^6.1.0",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-replace": "^6.0.3",
    "@types/jest": "^30.0.0",
    "@types/node": "^25",
    "@types/webpack-bundle-analyzer": "^4.7.0",
    "@typescript-eslint/eslint-plugin": "^8.53.1",
    "@typescript-eslint/parser": "^8.53.1",
    "concurrently": "^9.2.1",
    "dotenv": "^17.2.3",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.0.1",
    "globals": "^17.1.0",
    "husky": "^9.1.7",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.2.0",
    "knip": "^5.82.1",
    "lerna": "^9.0.3",
    "lint-staged": "^16.2.7",
    "nx": "^22.4.1",
    "prettier": "^3.8.1",
    "rollup": "^4.56.0",
    "rollup-plugin-preserve-directives": "^0.4.0",
    "rollup-plugin-visualizer": "^6.0.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.53.1",
    "webpack": "^5.104.1",
    "webpack-bundle-analyzer": "^5.2.0"
  },
  "lint-staged": {
    "**/*": "prettier --write --ignore-unknown"
  },
  "engines": {
    "node": ">=22"
  },
  "pnpm": {
    "overrides": {
      "@types/react": "^19.0.0",
      "tar": "^7.5.4",
      "braces": "^3.0.3",
      "micromatch": "^4.0.8",
      "cross-spawn": "^7.0.6",
      "mem": "^10.0.0",
      "yargs-parser": "^21.0.0"
    },
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "core-js",
      "nx",
      "sharp",
      "unrs-resolver"
    ]
  }
}
