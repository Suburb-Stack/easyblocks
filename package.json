{
  "name": "root",
  "private": true,
  "scripts": {
    "dev": "lerna run --stream dev --scope '@easyblocks/core' --scope '@easyblocks/editor'",
    "nuke": "./scripts/nuke.sh",
    "clean": "./scripts/clean.sh",
    "build": "nx run-many --target build --exclude website",
    "test": "nx run-many --target test",
    "lint": "nx affected --target lint --base origin/main -- --quiet",
    "lint:packages": "nx run-many --target lint --projects '@easyblocks/*' -- --quiet",
    "lint:all": "nx run-many --target lint -- --quiet",
    "check": "nx run-many --target check",
    "prepare": "husky",
    "publish-prerelease": "lerna version prerelease && npm run build && lerna publish from-git",
    "supabase-start": "supabase start",
    "supabase-stop": "supabase stop",
    "supabase-restart": "npm run supabase-stop && npm run supabase-start"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@babel/plugin-transform-runtime": "^7.24.0",
    "@babel/preset-env": "^7.24.0",
    "@babel/preset-react": "^7.24.0",
    "@babel/preset-typescript": "^7.24.0",
    "@jest/types": "^29.6.0",
    "@microsoft/api-extractor": "^7.43.0",
    "@rollup/plugin-babel": "^6.0.4",
    "@rollup/plugin-commonjs": "^28.0.0",
    "@rollup/plugin-json": "^6.1.0",
    "@rollup/plugin-node-resolve": "^16.0.0",
    "@rollup/plugin-replace": "^6.0.0",
    "@types/jest": "^29.5.0",
    "@types/node": "^22",
    "@types/webpack-bundle-analyzer": "^4.7.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "babel-plugin-styled-components": "^2.1.4",
    "concurrently": "^9.0.0",
    "dotenv": "^16.4.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^10.0.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "globals": "^16.0.0",
    "husky": "^9.0.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "knip": "^5.0.0",
    "lerna": "^8.0.0",
    "lint-staged": "^15.0.0",
    "nx": "^20.0.0",
    "prettier": "^3.2.0",
    "rollup": "^4.22.0",
    "rollup-plugin-preserve-directives": "^0.4.0",
    "rollup-plugin-visualizer": "^5.12.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.0.0",
    "webpack": "^5.90.0",
    "webpack-bundle-analyzer": "^4.10.0"
  },
  "lint-staged": {
    "**/*": "prettier --write --ignore-unknown"
  },
  "engines": {
    "node": ">=22"
  },
  "pnpm": {
    "overrides": {
      "@types/react": "^19.0.0"
    },
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "core-js",
      "nx",
      "sharp",
      "unrs-resolver"
    ]
  }
}
