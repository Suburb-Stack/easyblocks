{
  "name": "@suburb-stack/core",
  "type": "module",
  "version": "1.0.10-porting-to-next-16.a6b001d-porting-to-next-16.070c28a-main.85770d1",
  "description": "No-code ecommerce builder for headless CMS",
  "repository": {
    "type": "git",
    "url": "https://github.com/Suburb-Stack/easyblocks.git",
    "directory": "packages/core"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "scripts": {
    "dev": "NODE_ENV=development concurrently -n bundle,emit-declarations 'rollup -c rollup.config.js --watch' 'tsc --watch --preserveWatchOutput'",
    "build": "npm run bundle && npm run emit-declarations",
    "bundle": "NODE_ENV=production rollup -c rollup.config.js",
    "emit-declarations": "tsc",
    "bundle-declarations": "api-extractor run --local",
    "test": "jest",
    "check": "tsc && eslint --quiet src/"
  },
  "author": "Shopstory z o.o.",
  "license": "ISC",
  "dependencies": {
    "@babel/runtime": "^7.21.0",
    "@stitches/core": "^1.2.8",
    "js-xxhash": "^4.0.0",
    "lodash": "^4.17.21",
    "postcss-value-parser": "^3.3.0",
    "react-textarea-autosize": ">=7.1",
    "slate": "0.77.2",
    "slate-react": "0.77.2",
    "type-fest": "^3.0.0",
    "zod": "^3.21.4"
  },
  "devDependencies": {
    "@babel/core": "^7.28.6",
    "@babel/plugin-transform-runtime": "^7.28.5",
    "@jest/types": "^30.2.0",
    "@suburb-stack/build-tools": "workspace:*",
    "@suburb-stack/reduce-css-calc": "workspace:*",
    "@suburb-stack/test-utils": "workspace:*",
    "@suburb-stack/utils": "workspace:*",
    "@types/jest": "^30.0.0",
    "@types/lodash": "^4.17.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "jest": "^30.2.0"
  },
  "peerDependencies": {
    "react": "^16.8.0 || ^17.0.0-rc.1 || ^18.0.0 || ^19.0.0",
    "react-dom": "^16.8.0 || ^17.0.0-rc.1 || ^18.0.0 || ^19.0.0"
  },
  "main": "./dist/cjs/index.cjs",
  "module": "./dist/es/index.js",
  "types": "./dist/types/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/es/index.js",
      "require": "./dist/cjs/index.cjs"
    },
    "./_internals": {
      "types": "./dist/types/_internals.d.ts",
      "import": "./dist/es/_internals.js",
      "require": "./dist/cjs/_internals.cjs"
    }
  },
  "sideEffects": false,
  "files": [
    "dist/",
    "package.json",
    "LICENSE.md"
  ]
}
