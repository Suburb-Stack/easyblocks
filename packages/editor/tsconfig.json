{
  "extends": "../../base.tsconfig.json",
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "outDir": "./dist",
    "declaration": true,
    "emitDeclarationOnly": true,
    "declarationDir": "./dist",
    "paths": {
      "styled-components": ["./node_modules/styled-components"],
      "styled-components/*": ["./node_modules/styled-components/*"]
    }
  },
  "include": ["src/", "typings/"],
  "exclude": ["src/**/*.test.ts", "src/**/*.test.tsx", "src/utils/tests/**/*"],
  "ts-node": {
    "moduleTypes": {
      "jest.config.ts": "cjs"
    }
  }
}
